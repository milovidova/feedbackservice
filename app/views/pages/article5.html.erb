<script>
document.addEventListener('DOMContentLoaded', function() {

  const textLeft = document.querySelectorAll('.A_ArticleText') // едут влево
  const textRight = document.querySelectorAll('.A_ArticleText2') // едет вправо
  const tagRight = document.querySelectorAll('.A_ArticleTag') // едет вправо
  const middleRight = document.querySelectorAll('.W_ArticleMiddle') // едет вправо
  const text3InMiddle = document.querySelector('.A_ArticleText3') // текст внутри W_ArticleMiddle
  
  
  const images = [
    { element: document.querySelector('.Q_ArIm4'), speed: 0.8, direction: 1, startPos: 0 },
    { element: document.querySelector('.Q_ArIm3'), speed: 1.2, direction: -1, startPos: 0 },
    { element: document.querySelector('.Q_ArIm2'), speed: 1.0, direction: 1, startPos: 0 },
    { element: document.querySelector('.Q_ArIm5'), speed: 1.4, direction: -1, startPos: 0 },
    { element: document.querySelector('.Q_ArIm'), speed: 0.6, direction: 1, startPos: 0 },
  
  ].filter(item => item.element) 
  
  
  images.forEach(img => {
    const rect = img.element.getBoundingClientRect()
    img.startPos = rect.top + window.scrollY
    img.originalTransform = img.element.style.transform || 'translate(0px, 0px)'
  })
  
 
  const textLeftWidths = [604, 604] // Два блока A_ArticleText
  const textRightWidth = 688 // A_ArticleText2
  const text3Width = 604 // A_ArticleText3 внутри W_ArticleMiddle
  
 
  const maxScroll = document.documentElement.scrollHeight - window.innerHeight
  

  const minWidthLeft = 300
  const minWidthRight = 300
  

  const maxLeftOffset = -1200 
  const maxRightOffset = 1200
  
  function animateOnScroll() {
    const scrollY = window.scrollY
    const scrollProgress = Math.min(scrollY / maxScroll, 1)
    
   
    textLeft.forEach((element, index) => {
      const originalWidth = textLeftWidths[index] || 604
      const newWidth = Math.max(minWidthLeft, originalWidth - (originalWidth - minWidthLeft) * scrollProgress)
      const moveX = maxLeftOffset * scrollProgress 
      
      element.style.width = newWidth + 'px'
      element.style.transform = `translateX(${moveX}px)`
      element.style.textAlign = 'justify'
    })
    
    
    const rightOffset = maxRightOffset * scrollProgress
    
    textRight.forEach(element => {
      const newWidth = Math.max(minWidthRight, textRightWidth - (textRightWidth - minWidthRight) * scrollProgress)
      
      element.style.width = newWidth + 'px'
      element.style.transform = `translateX(${rightOffset}px)`
      element.style.textAlign = 'justify'
    })
    
   
    tagRight.forEach(element => {
      element.style.transform = `translateX(${rightOffset}px)`
    })
    

    middleRight.forEach(element => {
      element.style.transform = `translateX(${rightOffset}px)`
    })
    
   
    if (text3InMiddle) {
      const newWidth = Math.max(minWidthLeft, text3Width - (text3Width - minWidthLeft) * scrollProgress)
      text3InMiddle.style.width = newWidth + 'px'
      text3InMiddle.style.textAlign = 'justify'
    }
    

    images.forEach(img => {
      const rect = img.element.getBoundingClientRect()
      const elementTop = rect.top + scrollY
      const viewportHeight = window.innerHeight
      
   
      if (scrollY + viewportHeight > img.startPos && scrollY < img.startPos + 800) {
       
        const elementScrollStart = img.startPos - viewportHeight
        const elementScrollEnd = img.startPos + 500
        const elementProgress = Math.max(0, Math.min(1, 
          (scrollY - elementScrollStart) / (elementScrollEnd - elementScrollStart)
        ))
        
       
        let moveX = 0
        if (elementProgress < 0.5) {
       
          moveX = 1200 * img.speed * img.direction * (elementProgress * 2)
        } else {
    
          moveX = 1200 * img.speed * img.direction * (2 - elementProgress * 2)
        }
        
   
        img.element.style.transform = `translateX(${moveX}px)`
      } else {
       
        img.element.style.transform = img.originalTransform
      }
    })
  }
  
 
  let ticking = false
  
  window.addEventListener('scroll', () => {
    if (!ticking) {
      window.requestAnimationFrame(() => {
        animateOnScroll()
        ticking = false
      })
      ticking = true
    }
  })
  
  
  animateOnScroll()
})


</script>