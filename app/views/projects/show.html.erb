            <%= @project.feedback_request.presence || "Нет запроса" %>
          </div>
          

          <%= button_to 'удалить пост', project_path(@project), 
                        method: :delete, 
                        data: { confirm: 'Вы уверены, что хотите удалить этот проект?' },
