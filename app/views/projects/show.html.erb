              <path d="M12.9036 6.80408V17.3831H11.1654V6.80408L6.50336 11.4661L5.27441 10.2371L12.0345 3.47705L18.7946 10.2371L17.5657 11.4661L12.9036 6.80408Z" fill="#979797"/>
